# PsySense serverless local overrides
#
# Best practice for this repo:
# - Keep real backend secrets in the repo-root .env file.
# - Use serverless/.env only when you intentionally need a serverless-local
#   override. If the same key exists in both files, serverless/.env wins.
# - Never put secrets in serverless/frontend/.env* files.

# Optional override for question generation, transcription, and scoring.
# GROQ_API_KEY=gsk_your_key_here

# Optional serverless local runtime overrides.
# FRONTEND_URL=http://localhost:5173
# LOCAL_PORT=3001
# DYNAMODB_LOCAL_ENDPOINT=http://localhost:8000
# TABLE_NAME=psysense-local

# Optional n8n webhook overrides.
# N8N_INVITE_WEBHOOK=https://your-n8n-instance/webhook/invite
# N8N_RESULT_WEBHOOK=https://your-n8n-instance/webhook/result

# Optional Razorpay values.
# RAZORPAY_KEY_ID=rzp_test_xxx
# RAZORPAY_KEY_SECRET=xxx
