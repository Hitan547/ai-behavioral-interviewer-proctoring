# PsySense local backend secrets
#
# Copy this file to .env in the repo root for local development.
# Do not commit the real .env file.
#
# The serverless local API loads serverless/.env first, then this root .env as
# defaults. To avoid confusion, keep real secrets here and use serverless/.env
# only for temporary local overrides.

# Required for Groq transcription, question generation, and scoring.
GROQ_API_KEY=gsk_your_key_here
# GROQ_API_KEY_2=gsk_your_backup_key_here

# Optional n8n webhooks for local invite/result notifications.
N8N_INVITE_WEBHOOK=https://your-n8n-instance/webhook/invite
N8N_RESULT_WEBHOOK=https://your-n8n-instance/webhook/result

# Local app URLs.
APP_BASE_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
ANSWER_SERVICE_URL=http://localhost:5000

# Optional local serverless runtime overrides.
# LOCAL_PORT=3001
# DYNAMODB_LOCAL_ENDPOINT=http://localhost:8000
# TABLE_NAME=psysense-local

# Optional payment values.
# RAZORPAY_KEY_ID=rzp_test_xxx
# RAZORPAY_KEY_SECRET=xxx
